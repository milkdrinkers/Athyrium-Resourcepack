{
  "model": {
    "type": "condition",
    "property": "using_item",
    "on_true": {
      "type": "range_dispatch",
      "property": "custom_model_data",
      "entries": [],
      "fallback": {
        "type": "range_dispatch",
        "property": "crossbow/pull",
        "entries": [
          {
            "threshold": 0.58,
            "model": {
              "type": "model",
              "model": "item/crossbow_pulling_1",
              "tints": []
            }
          },
          {
            "threshold": 1.0,
            "model": {
              "type": "model",
              "model": "item/crossbow_pulling_2",
              "tints": []
            }
          }
        ],
        "fallback": {
          "type": "model",
          "model": "item/crossbow_pulling_0",
          "tints": []
        }
      }
    },
    "on_false": {
      "type": "range_dispatch",
      "property": "custom_model_data",
      "entries": [],
      "fallback": {
        "type": "select",
        "property": "charge_type",
        "cases": [
          {
            "when": "arrow",
            "model": {
              "type": "model",
              "model": "item/crossbow_arrow",
              "tints": []
            }
          },
          {
            "when": "rocket",
            "model": {
              "type": "model",
              "model": "item/crossbow_firework",
              "tints": []
            }
          }
        ],
        "fallback": {
          "type": "model",
          "model": "item/crossbow",
          "tints": []
        }
      }
    }
  }
}